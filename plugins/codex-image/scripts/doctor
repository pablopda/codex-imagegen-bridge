#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import tempfile
from pathlib import Path

CHATGPT_MARKERS = ("chatgpt", "subscription", "signed in", "logged in")
API_KEY_MARKERS = ("api key", "apikey", "api-key", "openai_api_key", "codex_api_key")
NEGATIVE_AUTH_MARKERS = ("not authenticated", "unauthenticated", "not logged in", "not signed in", "logged out")


def run(cmd: list[str], timeout: int = 5) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=False, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout)


def report(status: str, message: str) -> None:
    print(f"[{status}] {message}")


def resolve_executable(value: str) -> str | None:
    if os.sep in value:
        candidate = Path(value).expanduser()
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate.resolve())
        return None
    return shutil.which(value)


def auth_status(login_output: str) -> tuple[str, str]:
    lowered = login_output.lower()
    if any(marker in lowered for marker in NEGATIVE_AUTH_MARKERS):
        return "fail", "Codex login output indicates Codex is not authenticated. Run `codex login`."
    has_chatgpt = any(marker in lowered for marker in CHATGPT_MARKERS)
    has_api = any(marker in lowered for marker in API_KEY_MARKERS)
    if has_chatgpt and not has_api:
        return "ok", "Codex login output appears to indicate ChatGPT/authenticated usage."
    if has_api:
        return "warn", "Codex login output mentions API-key auth; ChatGPT quota use may not be active."
    return "warn", "Codex login succeeded, but auth type was not detectable from its output."


def build_bridge_dry_run_cmd(codex_bin: str, output_dir: Path) -> list[str] | None:
    bridge = Path(__file__).with_name("codex-imagegen")
    if bridge.is_file():
        return [
            str(bridge),
            "--codex-bin",
            codex_bin,
            "-p",
            "dry-run construction check only",
            "-f",
            str(output_dir / "doctor-dry-run.png"),
            "--dry-run",
        ]
    return None


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Check Codex ImageGen Bridge prerequisites without generating images.")
    parser.add_argument("--codex-bin", default="codex", help="Codex executable path. Default: codex")
    parser.add_argument("--output-dir", type=Path, help="Directory to test for writable output. Defaults to a temp directory.")
    args = parser.parse_args(argv)

    failures = 0
    codex_bin = resolve_executable(args.codex_bin)
    if codex_bin:
        report("ok", f"codex found at {codex_bin}")
    else:
        report("fail", "codex not found on PATH or explicit path is not executable. Install Codex CLI and run `codex login`.")
        return 1

    try:
        version = run([codex_bin, "--version"])
    except (OSError, subprocess.TimeoutExpired) as exc:
        report("fail", f"codex --version could not run: {exc}")
        failures += 1
    else:
        if version.returncode == 0:
            first_line = (version.stdout or version.stderr).strip().splitlines()[0:1]
            suffix = f": {first_line[0]}" if first_line else ""
            report("ok", f"codex --version exited successfully{suffix}")
        else:
            report("fail", "codex --version failed")
            failures += 1

    try:
        login = run([codex_bin, "login", "status"])
    except (OSError, subprocess.TimeoutExpired) as exc:
        report("fail", f"codex login status could not run: {exc}")
        failures += 1
    else:
        combined = f"{login.stdout}\n{login.stderr}"
        if login.returncode == 0:
            report("ok", "codex login status exited successfully")
            status, message = auth_status(combined)
            report(status, message)
            if status == "fail":
                failures += 1
        else:
            report("fail", "codex login status failed. Run `codex login` and prefer ChatGPT sign-in for quota-backed usage.")
            failures += 1

    output_dir = (args.output_dir or Path(tempfile.gettempdir()) / "codex-imagegen-bridge-doctor").expanduser().resolve()
    try:
        output_dir.mkdir(parents=True, exist_ok=True)
        test_file = output_dir / ".write-test"
        test_file.write_text("ok", encoding="utf-8")
        test_file.unlink()
    except OSError as exc:
        report("fail", f"output directory is not writable: {output_dir} ({exc})")
        failures += 1
    else:
        report("ok", f"output directory is writable: {output_dir}")

    dry_run_cmd = build_bridge_dry_run_cmd(codex_bin, output_dir)
    if dry_run_cmd is None:
        report("fail", "bridge dry-run command construction failed: bridge script was not found")
        failures += 1
    else:
        try:
            dry_run = run(dry_run_cmd, timeout=5)
        except (OSError, subprocess.TimeoutExpired) as exc:
            report("fail", f"bridge dry-run command construction failed: {exc}")
            failures += 1
        else:
            if dry_run.returncode == 0 and "Codex command:" in dry_run.stdout and "Generated Codex prompt:" in dry_run.stdout:
                report("ok", "bridge dry-run prints command and prompt without invoking $imagegen")
            else:
                report("fail", "bridge dry-run command construction failed")
                failures += 1

    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
